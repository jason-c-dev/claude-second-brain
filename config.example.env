# Claude Second Brain — Configuration
# Copy this file to config.env and fill in your values:
#   cp config.example.env config.env

# ──────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────
# Your Telegram chat ID — the bot sends dream reports and status messages here.
# To find your chat_id: message your bot, then visit
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ──────────────────────────────────────────────
# Webhook
# ──────────────────────────────────────────────
# Port for the webhook-channel HTTP server. Change if running multiple instances.
WEBHOOK_PORT=8790

# ──────────────────────────────────────────────
# Voice Transcription (optional)
# ──────────────────────────────────────────────
# Only needed if you want to receive and transcribe Telegram voice messages.
# Requires: whisper.cpp (https://github.com/ggerganov/whisper.cpp) and ffmpeg.
#
# Path to your whisper.cpp GGML model file:
# STT_MODEL=/opt/homebrew/share/whisper-cpp/models/ggml-base.en.bin
#
# Override the whisper binary name (default: whisper-cli):
# STT_PATH=whisper-cli

# ──────────────────────────────────────────────
# Obsidian (optional)
# ──────────────────────────────────────────────
# Only needed if this repo is NOT your Obsidian vault (i.e., you keep them separate).
# If the repo IS the vault (the default, simplest setup), leave these commented out.
#
# OBSIDIAN_VAULT=/path/to/your/obsidian/vault
# OBSIDIAN_VAULT_NAME=Vault
