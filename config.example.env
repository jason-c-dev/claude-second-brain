# Claude Second Brain — Configuration
# Copy this file to config.env and fill in your values:
#   cp config.example.env config.env

# ──────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────
# Your personal Telegram chat ID (a numeric ID, NOT the bot token).
# This is where Claude sends dream reports and status messages.
#
# To find it: message @userinfobot on Telegram — it replies with your ID.
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ──────────────────────────────────────────────
# Webhook & Voice
# ──────────────────────────────────────────────
# Webhook port and voice model path are configured in .mcp.json (not here),
# because MCP servers read their env from .mcp.json directly.
# If running multiple instances, change WEBHOOK_PORT in .mcp.json and
# update .config/crontab to match.

