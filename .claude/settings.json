{
  "enabledPlugins": {
    "obsidian@obsidian-skills": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.hooks/telegram_gate.py\" UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.hooks/telegram_gate.py\" PreToolUse",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
