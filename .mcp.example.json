{
  "mcpServers": {
    "webhook-channel": {
      "command": "bun",
      "args": ["run", ".channels/webhook-channel/src/index.ts"],
      "env": {
        "WEBHOOK_PORT": "8790"
      }
    },
    "voice-tools": {
      "command": "bun",
      "args": ["run", ".tools/voice-tools/src/index.ts"],
      "env": {
        "STT_MODEL": "/path/to/whisper-cpp/models/ggml-base.en.bin"
      }
    },
    "telegram": {
      "command": "bun",
      "args": ["run", "--cwd", "TELEGRAM_PLUGIN_PATH", "--shell=bun", "--silent", "start"],
      "env": {
        "TELEGRAM_STATE_DIR": "TELEGRAM_STATE_DIR_PATH"
      }
    }
  }
}
